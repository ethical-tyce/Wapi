{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wapi IDE",
  "version": "0.1.0",
  "identifier": "dev.wapi.ide",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Wapi IDE",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "backgroundColor": "#090b09",
        "dragDropEnabled": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icon.ico"
    ]
  }
}
