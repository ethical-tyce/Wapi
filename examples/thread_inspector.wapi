#name "Thread inspector"
#version "1.0.0"
#author "Wapi examples"
#description "Lists the threads owned by a process. Requires dev mode for thread + debug capabilities."
#mode dev
#strict
#cap proc.list thread.list runtime.print

let target = "notepad"
var pid = proc.find(target)

if pid == 0 {
    print("{target} is not running")
} else {
    // listThreads prints "<tid> - pid=<pid>" for every thread it finds.
    print("threads owned by {target} (pid={pid}):")
    listThreads(pid)
}
